# Docker Environment Configuration
# Copy this file to .env.docker and customize as needed

# ===================
# Database Selection
# ===================
# Options: sqlite, mysql, postgres
# Leave empty for SQLite (default, no external DB)
# DB_DRIVER=mysql
# DB_DRIVER=postgres

# ===================
# SQLite Configuration
# ===================
# Path for SQLite database file (inside API container)
DB_SQLITE_PATH=/var/www/html/data/jajat.sqlite

# ===================
# MySQL Configuration
# ===================
# MySQL connection settings (used when DB_DRIVER=mysql)
# ⚠️ CHANGE these defaults before deploying! Weak credentials are a security risk.
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=jatuser
MYSQL_PASSWORD=jatpassword
DB_NAME=jajat

# ===================
# PostgreSQL Configuration  
# ===================
# PostgreSQL connection settings (used when DB_DRIVER=postgres)
# ⚠️ CHANGE these defaults before deploying! Weak credentials are a security risk.
POSTGRES_USER=jatuser
POSTGRES_PASSWORD=jatpassword
DB_NAME=jajat

# ===================
# CORS Configuration
# ===================
# Allowed origins for API CORS (comma-separated)
# Default: http://localhost:5173 (dev only)
# For production, set to your domain(s), e.g.: https://jajat.example.com
ALLOWED_ORIGINS=http://localhost:5173

# ===================
# Google OAuth (optional)
# ===================
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret