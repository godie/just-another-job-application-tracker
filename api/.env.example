# Local development secrets for the PHP backend.
#
# Copy this file to api/.env (same directory) and fill in real values.
# `api/.env` is gitignored so your secrets never leak.
#
# `api/config.example.php` reads each variable with `getenv(KEY)` at startup,
# so any key listed here becomes the source of truth for that setting.
# The deploy workflow writes a similar file from GitHub Secrets.

# ---------- Observability (Logfire / OpenTelemetry) ----------
# Required to enable backend trace export. Leave empty to disable telemetry
# entirely — LogfireTelemetry.php silently becomes a no-op tracer.
# Get a write token from https://logfire-us.pydantic.dev after creating
# the 'godi/starter-project' project, then paste it below.
LOGFIRE_TOKEN=

# Optional. Defaults to 'overphp-api' when unset. Used as the service.name
# resource attribute so traces are easy to filter in Logfire's Live view.
# For local dev, anything human-readable works (e.g. jajat-local).
OTEL_SERVICE_NAME=jajat-local

# Optional. Override only if self-hosting Logfire. The default already
# points to the project-shared US endpoint at logfire-us.pydantic.dev.
# LOGFIRE_BASE_URL=https://logfire-us.pydantic.dev

# ---------- Database ----------
# Toggle to 'false' for a session-only local dev without MySQL.
DB_ENABLED=false
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
