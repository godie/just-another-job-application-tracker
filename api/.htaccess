# Security header: allow Google OAuth popup to check window.closed without COOP errors
# 'same-origin-allow-popups' is the recommended value for OAuth popup flows
Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"

RewriteEngine On
# Proteger archivos sensibles
<Files ".env">
    Order allow,deny
    Deny from all
</Files>
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Evita que se apliquen reglas si el archivo o carpeta real existe
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Manda todo lo que no exista a index.php dentro de /api
RewriteRule ^(.*)$ index.php [L,QSA]
