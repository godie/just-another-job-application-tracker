{
  "name": "godie/overphp",
  "description": "Minimal PHP API framework with static client serving and CLI support",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Diego Mendoza",
      "email": "godie.mendoza@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "robmorgan/phinx": "^0.16.11"
  },
  "bin": [
    "bin/overphp"
  ],
  "autoload": {
    "psr-4": {
      "OverPHP\\": "src/"
    },
    "files": [
      "src/Helpers/cors.php",
      "src/Helpers/database.php",
      "src/Helpers/appAuth.php",
      "src/Helpers/agentAuth.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "OverPHP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "phinx": "vendor/bin/phinx -c ../phinx.php"
  }
}
