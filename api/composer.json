{
  "name": "godie/overphp",
  "description": "Minimal PHP API framework with static client serving and CLI support",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Diego Mendoza",
      "email": "godie.mendoza@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4.1",
    "open-telemetry/sdk": "^1.14",
    "open-telemetry/exporter-otlp": "^1.4",
    "php-http/curl-client": "^2.4",
    "nyholm/psr7": "^1.8",
    "symfony/http-client": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "robmorgan/phinx": "^0.16.12",
    "phpstan/phpstan": "^2",
    "rector/rector": "^2"
  },
  "bin": [
    "bin/overphp"
  ],
  "autoload": {
    "psr-4": {
      "OverPHP\\": "src/"
    },
    "files": [
      "src/Helpers/cors.php",
      "src/Helpers/database.php",
      "src/Helpers/appAuth.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "OverPHP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "phinx": "vendor/bin/phinx -c ../phinx.php"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "tbachert/spi": true
    }
  }
}
